{
  "name": "cnvtr",
  "version": "1.0.0",
  "description": "Convert public media URLs to high-quality audio (MP3, WAV) for creators, DJs, and producers",
  "main": "main.js",
  "author": "CNVTR",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win --config.win.signAndEditExecutable=false",
    "build:mac": "vite build && electron-builder --mac",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --config.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "music-metadata": "^9.0.1",
    "node-id3": "^0.2.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cnvtr.app",
    "productName": "CNVTR",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "backend/**/*",
      "assets/**/*",
      "yt-dlp/**/*",
      "ffmpeg/**/*"
    ],
    "asarUnpack": [
      "yt-dlp/**",
      "ffmpeg/**"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
